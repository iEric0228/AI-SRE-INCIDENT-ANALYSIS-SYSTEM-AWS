[flake8]
# Flake8 configuration for code linting

max-line-length = 100
exclude = 
    .git,
    __pycache__,
    .pytest_cache,
    .venv,
    venv,
    ENV,
    env,
    build,
    dist,
    .terraform,
    *.egg-info

# Error codes to ignore
ignore =
    E203,
    E501,
    W503

# Complexity
# Set to 15 to accommodate the inherently branchy multi-resource-type ARN
# parsers and event handlers (event_transformer, logs/metrics collectors),
# which top out at complexity 15. Splitting them further hurts readability.
max-complexity = 15

# Per-file ignores
per-file-ignores =
    __init__.py:F401
    tests/*:F401,F811,E402,F841,F541,E712,E226,C901
